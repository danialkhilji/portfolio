---
import { Icon } from "astro-icon/components";

interface Props {
  label: string;
  icon?: string;
  iconType?: "iconify" | "local";
}

const { label, icon, iconType = "iconify" } = Astro.props;
---

{icon ? (
  <div class="skill-badge inline-flex flex-col items-center justify-center w-24 h-24 m-2 rounded-xl border border-dark-border bg-dark-card cursor-default transition-all duration-300 hover:border-dark-accent/50 hover:bg-dark-card-hover">
    {iconType === "local" ? (
      <img
        src={`${import.meta.env.BASE_URL}${icon}`}
        alt={label}
        class="skill-icon w-10 h-10 object-contain grayscale transition-[filter] duration-300"
      />
    ) : (
      <Icon
        name={icon}
        class="skill-icon w-10 h-10 grayscale transition-[filter] duration-300"
      />
    )}
    <span class="text-xs text-dark-text-muted mt-2 text-center leading-tight px-1">{label}</span>
  </div>
) : (
  <span class="inline-block bg-dark-card text-dark-text-secondary border border-dark-border px-3.5 py-1.5 m-1.5 rounded-full text-sm font-medium cursor-default transition-colors duration-300 hover:border-dark-accent/50 hover:bg-dark-card-hover">
    {label}
  </span>
)}

<style>
  .skill-badge:hover .skill-icon {
    filter: grayscale(0);
  }
</style>
