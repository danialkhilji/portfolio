---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span
  class="inline-block bg-dark-card text-dark-text-secondary border border-dark-border px-3.5 py-1.5 m-1.5 rounded-full font-medium cursor-default transition-colors duration-300 hover:bg-dark-accent hover:text-dark-bg hover:border-dark-accent"
>
  {label}
</span>
